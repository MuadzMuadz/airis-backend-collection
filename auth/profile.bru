meta {
  name: profile
  type: http
  seq: 3
}

get {
  url: {{baseUrl}}/api/v1/auth/me
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const data = res.getBody();

  if (data && data.id) {
    _ = bru.setEnvVar("user_id", data.id);
    console.log("user_id saved:", data.id);
  }
}
