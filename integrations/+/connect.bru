meta {
  name: Connect Zotero
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/integrations/zotero/connect
  body: none
  auth: bearer
}

auth:bearer {
  token: {{token}}
}

script:post-response {
  const data = res.getBody();

  if (data && data.oauth_token_secret) {
    bru.setEnvVar("zotero_oauth_token_secret", data.oauth_token_secret);
    console.log("Zotero OAuth Token Secret saved.");
    console.log("Authorization URL: " + data.authorization_url);
  }
}
