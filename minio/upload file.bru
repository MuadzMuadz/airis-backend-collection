meta {
  name: upload file
  type: http
  seq: 3
}

post {
  url: {{baseUrl}}/api/v1/minio/upload
  body: multipartForm
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

body:multipart-form {
  file:
  session_id: {{session_id}}
  auto_ingest: true
  ~session_id:
}
