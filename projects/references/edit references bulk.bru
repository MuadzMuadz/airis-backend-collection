meta {
  name: edit references bulk
  type: http
  seq: 1
}

patch {
  url: {{baseUrl}}/api/v1/projects/references/bulk?project_id={{active_project_id}}
  body: json
  auth: bearer
}

params:query {
  project_id: {{active_project_id}}
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  "reference_ids": ["uuid-1", "uuid-2"],
  "target_folder_id": "uuid-folder"
}
