meta {
  name: edit references
  type: http
  seq: 1
}

patch {
  url: {{baseUrl}}/api/v1/projects/references
  body: json
  auth: bearer
}

headers {
  Accept: application/json
}

auth:bearer {
  token: {{token}}
}

body:json {
  {
    "id": "{{ref_id}}",
    "project_folder_id": "{{folder_id}}"
  }
}
